# Florina — environment variable template.
#
# Copy to `.env` (which is git-ignored) and fill in real values for local dev,
# or set these in your host's secret manager (Railway variables) for prod.
# NEVER commit a filled-in `.env`. This `.example` holds placeholders only.

# --- Required in production (the app raises at boot if any is missing) ---
# Phoenix secret for signing cookies. Generate with: mix phx.gen.secret
SECRET_KEY_BASE=replace-with-64-byte-secret
# Control-plane Postgres URL (tenants get their own DBs on the same server).
DATABASE_URL=ecto://USER:PASSWORD@HOST:5432/florina
# AES-256-GCM key for field encryption (Cloak). 32 random bytes, base64.
# Generate with: elixir -e ':crypto.strong_rand_bytes(32) |> Base.encode64() |> IO.puts()'
FIELD_ENCRYPTION_KEY=replace-with-base64-32-byte-key
# Basic-auth password for the shared /chat demo dashboard.
DASHBOARD_PASS=replace-with-strong-password

# --- Phoenix / runtime (optional; sensible defaults shown) ---
PHX_HOST=app.example.com
PHX_SERVER=true
PORT=4000
POOL_SIZE=10
# ECTO_IPV6=true
# DNS_CLUSTER_QUERY=
TENANT_BASE_HOST=app.example.com
DASHBOARD_USER=admin

# --- First operator admin (seeded once at boot if the admins table is empty) ---
ADMIN_EMAIL=ops@example.com
ADMIN_PASSWORD=replace-with-strong-password

# --- Anthropic (LLM: chat + prompt assembly + lessons) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- ElevenLabs (outbound AI voice calls + inbound webhook) ---
ELEVENLABS_API_KEY=sk_xxxxxxxx
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=wsec_xxxxxxxx

# --- Google OAuth (agent sign-in + calendar) — one app, shared by all tenants ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft / Entra OAuth (agent sign-in + calendar) — one app, shared ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# "organizations" = work/school accounts only (recommended). Or a directory id.
MICROSOFT_TENANT=organizations

# --- Shared OAuth callback base (optional; falls back to PHX_HOST) ---
# OAUTH_REDIRECT_BASE=https://app.example.com

# --- Pipedrive (CRM sync) ---
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMAIN=yourcompany
