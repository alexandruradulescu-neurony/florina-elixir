# Sales Assistant — environment template
# Copy to `.env` and fill in the values. Real keys for the demo
# are shared separately by the project owner.

# ─── Django ───
DEBUG=True
SECRET_KEY=django-insecure-change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,sales-assist.ngrok.app
CSRF_TRUSTED_ORIGINS=http://localhost:8007,http://127.0.0.1:8007,https://sales-assist.ngrok.app

# ─── Field encryption (Google OAuth secrets at rest) ───
# REQUIRED in any environment that stores Google OAuth credentials. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: if this key is lost or changed, stored OAuth credentials become
# unreadable and affected users must re-authenticate Google. Keep it safe and
# stable (treat like SECRET_KEY).
FIELD_ENCRYPTION_KEY=

# ─── Postgres database ───
# Create a local database first:
#   createdb salesassistant
#   createuser django_user --pwprompt
#   psql -c "GRANT ALL PRIVILEGES ON DATABASE salesassistant TO django_user;"
DB_NAME=salesassistant
DB_USER=django_user
DB_PASSWORD=replace_with_your_local_db_password
DB_HOST=localhost
DB_PORT=5432

# ─── ngrok (for ElevenLabs webhook tunneling) ───
# The demo uses a reserved subdomain. If you have your own, set it here
# AND update the webhook URL in the ElevenLabs dashboard accordingly.
NGROK_URL=https://sales-assist.ngrok.app

# ─── Anthropic Claude (post-call analysis + Romanian summaries) ───
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── ElevenLabs Conversational AI (outbound voice calls) ───
# Set up:
#   1. Create an agent in https://elevenlabs.io/app/conversational-ai
#   2. Enable "Allow Overrides" for System Prompt + First Message
#      (Agent → Security → Overrides)
#   3. Provision a phone number (Conversational AI → Phone Numbers)
#   4. Configure webhook URL: https://sales-assist.ngrok.app/webhooks/elevenlabs/
# Copy the IDs here:
ELEVENLABS_AGENT_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=

# ─── Optional: LLM model override (defaults to claude-sonnet-4-20250514) ───
# LLM_MODEL=claude-sonnet-4-20250514
