SECRETS=$(sindri secrets fetch --from vm-defaults master master_ssh_key user user_ssh_key github_deploy_ssh_key op_user op_ssh_key)

MASTER=$(sindri secrets extract master $SECRETS)
MASTER_SSH_KEY=$(sindri secrets extract master_ssh_key $SECRETS)
USER=$(sindri secrets extract user $SECRETS)
USER_SSH_KEY=$(sindri secrets extract user_ssh_key $SECRETS)
GITHUB_DEPLOY_SSH_KEY=$(sindri secrets extract github_deploy_ssh_key $SECRETS)
OP_USER=$(sindri secrets extract op_user $SECRETS)
OP_SSH_KEY=$(sindri secrets extract op_ssh_key $SECRETS)
